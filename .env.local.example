# -------------------------------------------------------------------------------------------------
# environment variables
# -------------------------------------------------------------------------------------------------
# - public environment variables must be prefixed with `NEXT_PUBLIC_`.
# - when adding new environment variables, don't forget to also update the
#   validation schema in `./config/env.config.js`.

# -------------------------------------------------------------------------------------------------
# app
# -------------------------------------------------------------------------------------------------
NEXT_PUBLIC_APP_BASE_URL="http://localhost:3000"
# imprint service
NEXT_PUBLIC_REDMINE_ID="22513"
# web crawlers
NEXT_PUBLIC_BOTS="disabled"
# validate environment variables
ENV_VALIDATION="enabled"

# -------------------------------------------------------------------------------------------------
# analytics
# -------------------------------------------------------------------------------------------------
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_MATOMO_BASE_URL="https://matomo.acdh.oeaw.ac.at"
# NEXT_PUBLIC_MATOMO_ID=

# -------------------------------------------------------------------------------------------------
# auth
# -------------------------------------------------------------------------------------------------
# 128 bit (16 byte) base64-encoded string: `openssl rand --base64 16`.
ENCRYPTION_KEY=

# -------------------------------------------------------------------------------------------------
# db
# -------------------------------------------------------------------------------------------------
DB_HOST="localhost"
DB_NAME="dariah-knowledge-base"
DB_PASSWORD=
DB_PORT="5432"
DB_USER="dariah-knowledge-base"

# -------------------------------------------------------------------------------------------------
# email
# -------------------------------------------------------------------------------------------------
EMAIL_ADDRESS=
# EMAIL_SMTP_USERNAME=
# EMAIL_SMTP_PASSWORD=
EMAIL_SMTP_SERVER="smtp.oeaw.ac.at"
EMAIL_SMTP_PORT="587"

# -------------------------------------------------------------------------------------------------
# sshoc marketplace
# -------------------------------------------------------------------------------------------------
SSHOC_MARKETPLACE_API_BASE_URL="https://marketplace-api.sshopencloud.eu"
SSHOC_MARKETPLACE_BASE_URL="https://marketplace.sshopencloud.eu"
SSHOC_MARKETPLACE_PASSWORD=
SSHOC_MARKETPLACE_USERNAME=

# -------------------------------------------------------------------------------------------------
# keystatic cms
# -------------------------------------------------------------------------------------------------
# KEYSTATIC_GITHUB_CLIENT_ID=
# KEYSTATIC_GITHUB_CLIENT_SECRET=
# KEYSTATIC_SECRET=
# NEXT_PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=
# NEXT_PUBLIC_KEYSTATIC_GITHUB_REPO_NAME="dariah-knowledge-base"
# NEXT_PUBLIC_KEYSTATIC_GITHUB_REPO_OWNER="dariah-eric"
# NEXT_PUBLIC_KEYSTATIC_MODE="github"

# -------------------------------------------------------------------------------------------------
# open telemetry
# -------------------------------------------------------------------------------------------------
# development setup: https://github.com/vercel/opentelemetry-collector-dev-setup
# acdh-ch collector url: "http://k8s-infra-otel-agent.signoz-k8s-infra:4318"
# OPENTELEMETRY_COLLECTOR_URL="http://localhost:4318"
# OPENTELEMETRY_SERVICE_NAME=

# -------------------------------------------------------------------------------------------------
# sentry error reporting
# -------------------------------------------------------------------------------------------------
# SENTRY_AUTH_TOKEN=
